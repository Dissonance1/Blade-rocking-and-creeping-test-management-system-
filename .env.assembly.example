# =============================================================================
# Assembly Station (720 Hanger) — Environment Configuration
# Copy to .env.assembly and fill in real values.  NEVER commit .env.assembly.
# =============================================================================

# Station identity
STATION_ROLE=ASSEMBLY

# URL of the OH PC's application on the LAN.
# Set to the OH PC's LAN IP address, e.g. http://192.168.1.50
OH_SYNC_URL=http://REPLACE_WITH_OH_PC_LAN_IP

# Shared API key — must match OH_SYNC_API_KEY in .env.oh on the OH PC
OH_SYNC_API_KEY=REPLACE_WITH_SHARED_SYNC_KEY

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://blade_user:changeme_db_assembly@assembly_postgres:5432/blade_rocking_assembly
POSTGRES_DB=blade_rocking_assembly
POSTGRES_USER=blade_user
POSTGRES_PASSWORD=changeme_db_assembly

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:changeme_redis_assembly@assembly_redis:6379/0
REDIS_PASSWORD=changeme_redis_assembly
CELERY_BROKER_URL=redis://:changeme_redis_assembly@assembly_redis:6379/1
CELERY_RESULT_BACKEND=redis://:changeme_redis_assembly@assembly_redis:6379/2

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate independently — Assembly and OH use different JWT secrets.
# python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET_KEY

# ─── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
OCR_PROVIDER=paddleocr
MAX_FILE_SIZE_MB=10

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=
