# =============================================================================
# Blade Rocking & Creep Test Management System — Environment Variables
#
# PRIVATE NETWORK DEPLOYMENT
# Copy this file to .env and fill in your values before running docker-compose.
# Never commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME="Blade Rocking & Creep Test Management System"
APP_VERSION="1.0.0"
ENVIRONMENT=production
DEBUG=false

# ---------------------------------------------------------------------------
# Security — CHANGE ALL OF THESE BEFORE FIRST DEPLOYMENT
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------------------------
SECRET_KEY=change_this_to_a_random_64_char_hex_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# Database (PostgreSQL 15) — internal only, never exposed to host network
# ---------------------------------------------------------------------------
POSTGRES_DB=blade_rocking
POSTGRES_USER=blade_user
POSTGRES_PASSWORD=change_this_strong_db_password
DATABASE_URL=postgresql+asyncpg://blade_user:change_this_strong_db_password@postgres:5432/blade_rocking

# ---------------------------------------------------------------------------
# Redis — internal only
# ---------------------------------------------------------------------------
REDIS_PASSWORD=change_this_redis_password
REDIS_URL=redis://:change_this_redis_password@redis:6379/0

# ---------------------------------------------------------------------------
# Celery
# ---------------------------------------------------------------------------
CELERY_BROKER_URL=redis://:change_this_redis_password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:change_this_redis_password@redis:6379/2

# ---------------------------------------------------------------------------
# CORS — set to the server's LAN IP or internal hostname
# Examples: http://192.168.1.50  or  http://blade-rocking.local
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://192.168.1.50

# ---------------------------------------------------------------------------
# File storage
# ---------------------------------------------------------------------------
UPLOAD_DIR=/app/uploads
REPORTS_DIR=/app/reports
MAX_FILE_SIZE_MB=10

# ---------------------------------------------------------------------------
# OCR Provider: mock | tesseract | paddleocr
# Use "mock" until physical OCR hardware is integrated
# ---------------------------------------------------------------------------
OCR_PROVIDER=mock

# ---------------------------------------------------------------------------
# Email (optional) — point to internal SMTP relay on the plant network
# Leave SMTP_HOST blank to disable email notifications entirely
# ---------------------------------------------------------------------------
SMTP_HOST=192.168.1.10
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@blade-rocking.local
EMAILS_FROM_NAME="Blade Rocking System"

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
