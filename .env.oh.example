# =============================================================================
# OH Station (701 Hanger) — Environment Configuration
# Copy to .env.oh and fill in real values.  NEVER commit .env.oh to git.
# =============================================================================

# Station identity
STATION_ROLE=OH

# ─── Database ─────────────────────────────────────────────────────────────────
# Internal container hostname used by docker-compose.oh.yml
DATABASE_URL=postgresql+asyncpg://blade_user:changeme_db_oh@oh_postgres:5432/blade_rocking_oh
POSTGRES_DB=blade_rocking_oh
POSTGRES_USER=blade_user
POSTGRES_PASSWORD=changeme_db_oh

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:changeme_redis_oh@oh_redis:6379/0
REDIS_PASSWORD=changeme_redis_oh
CELERY_BROKER_URL=redis://:changeme_redis_oh@oh_redis:6379/1
CELERY_RESULT_BACKEND=redis://:changeme_redis_oh@oh_redis:6379/2

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET_KEY

# Shared API key used by Assembly PC to call the OH sync endpoints.
# Set the same value in .env.assembly on the Assembly PC.
OH_SYNC_API_KEY=REPLACE_WITH_SHARED_SYNC_KEY

# ─── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
OCR_PROVIDER=paddleocr
MAX_FILE_SIZE_MB=10

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Allow the Assembly PC browser to call OH APIs if needed.
# Example: CORS_ORIGINS=http://192.168.1.60,https://192.168.1.60
CORS_ORIGINS=
