# =============================================================================
# Frontend environment — Blade Rocking & Creep Test System
#
# PRIVATE NETWORK DEPLOYMENT:
#   In production (behind NGINX), leave VITE_API_BASE_URL and VITE_WS_URL
#   EMPTY — the browser hits the same origin and NGINX routes /api/* to the
#   backend automatically. No hardcoded server IP needed in the frontend.
#
# For local development only (running `npm run dev` on your laptop):
#   VITE_API_BASE_URL=http://192.168.1.50:8000
#   VITE_WS_URL=ws://192.168.1.50:8000
# =============================================================================

# Leave blank for Docker/NGINX deployment (same-origin proxying)
VITE_API_BASE_URL=
VITE_WS_URL=

VITE_APP_TITLE=Blade Rocking & Creep Test System
VITE_APP_VERSION=1.0.0
